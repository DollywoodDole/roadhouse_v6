# ============================================
# RoadHouse v6 — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SOLANA / WEB3
# ============================================

# 'devnet' for testing | 'mainnet-beta' for production
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Optional custom RPC (Helius, QuickNode). Leave blank = public endpoint.
NEXT_PUBLIC_SOLANA_RPC=

# $ROAD SPL Token mint address — set after running: npm run mint-token
NEXT_PUBLIC_ROAD_MINT_ADDRESS=

# NFT Collection addresses — set after Candy Machine deployment
NEXT_PUBLIC_NFT_FOUNDING_COLLECTION=
NEXT_PUBLIC_NFT_REGULAR_COLLECTION=
NEXT_PUBLIC_NFT_RANCH_COLLECTION=
NEXT_PUBLIC_NFT_PARTNER_COLLECTION=

# Treasury (Gnosis Safe multisig)
NEXT_PUBLIC_TREASURY_WALLET=
NEXT_PUBLIC_MULTISIG_WALLET=

# ============================================
# STRIPE
# ============================================

STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Merch (one-time)
NEXT_PUBLIC_STRIPE_PRICE_TEE=price_1TARiADv5Ly4OO7EjpVAl2xb
NEXT_PUBLIC_STRIPE_PRICE_HAT=price_1TARhODv5Ly4OO7EtU26XcKh
NEXT_PUBLIC_STRIPE_PRICE_HOODIE=price_1TARiSDv5Ly4OO7E1pSanRFJ
NEXT_PUBLIC_STRIPE_PRICE_STICKERS=price_1TARn2Dv5Ly4OO7E5Ci08aGJ
NEXT_PUBLIC_STRIPE_PRICE_GLASS=price_1TARimDv5Ly4OO7EabUVfFXI
NEXT_PUBLIC_STRIPE_PRICE_PHONE=price_1TARizDv5Ly4OO7E3norq216

# Memberships (recurring) — $19.99 / $99.99 / $199.98 per month CAD
NEXT_PUBLIC_STRIPE_SUB_REGULAR=price_1TDtTLDv5Ly4OO7EB0NgxoLA
NEXT_PUBLIC_STRIPE_SUB_RANCH=price_1TDtTLDv5Ly4OO7EBsQt7Kl3
NEXT_PUBLIC_STRIPE_SUB_PARTNER=price_1TDtTMDv5Ly4OO7EqrFypjkI

# Event Tickets — $999 / $1,599 / $299 CAD
NEXT_PUBLIC_STRIPE_PRICE_SKMT=price_1TDtTODv5Ly4OO7EGfwW2sBv
NEXT_PUBLIC_STRIPE_PRICE_SUMMIT=price_1TDtTPDv5Ly4OO7Er1RCjrZX
NEXT_PUBLIC_STRIPE_PRICE_SUMMIT_VIP=price_1TCXmlDv5Ly4OO7EEPV6lR5J

# Sponsorship Packages (recurring/mo) — $1,000 / $2,500 / $10,000 CAD
NEXT_PUBLIC_STRIPE_PRICE_SPONSOR_TB=price_1TDtTQDv5Ly4OO7EvRXXuqRE
NEXT_PUBLIC_STRIPE_PRICE_SPONSOR_FR=price_1TDtTSDv5Ly4OO7EJex8Efpb
NEXT_PUBLIC_STRIPE_PRICE_SPONSOR_PR=price_1TDtTSDv5Ly4OO7EU39UyWcs

# Digital Products (one-time) — $129.99 / $295.99 CAD
NEXT_PUBLIC_STRIPE_PRICE_PLAYBOOK=price_1TDtTNDv5Ly4OO7E1zGSrUoX
NEXT_PUBLIC_STRIPE_PRICE_TOOLKIT=price_1TDtTODv5Ly4OO7EQF9nfXtw

# Adventures — deposits (not full trip cost)
# Lake: $199 CAD deposit / BC or AB / Summer 2026
NEXT_PUBLIC_STRIPE_PRICE_ADV_LAKE=price_1TCVbjDv5Ly4OO7EUuVOraPt
# Ski: $299 CAD deposit / Panorama or Whitefish / Winter 2026-27
NEXT_PUBLIC_STRIPE_PRICE_ADV_SKI=price_1TCVbkDv5Ly4OO7EknTelFmv
# Med: $1,000 CAD hold / Mediterranean / Summer 2027 / Ranch Hand+ only
NEXT_PUBLIC_STRIPE_PRICE_ADV_MED=price_1TDtTQDv5Ly4OO7EFZGYVb2D

# ============================================
# DISCORD BOT
# ============================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=960258931257667625
# From Discord Developer Portal → Your App → General Information
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
# Role IDs — copy from Discord Server Settings > Roles > (right-click > Copy ID)
DISCORD_ROLE_REGULAR=1484662358495461467
DISCORD_ROLE_RANCH_HAND=1484662734992838737
DISCORD_ROLE_PARTNER=1484662919798063255
# Random secrets — generate with: openssl rand -base64 32
DISCORD_VERIFY_SECRET=
DISCORD_ADMIN_SECRET=

# ============================================
# EMAIL — RESEND
# ============================================
RESEND_API_KEY=re_...
FROM_EMAIL=hello@roadhouse.capital
RESEND_FROM_EMAIL=hello@roadhouse.capital
# Resend domain must be verified at resend.com/domains for roadhouse.capital
# NEXT_PUBLIC_CONTACT_EMAIL is set below in the CONTACT section

# ============================================
# VERCEL KV — OFF-CHAIN $ROAD BALANCE
# ============================================
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Set via: vercel env pull (auto-populated when KV store is linked in Vercel dashboard)

# ============================================
# FEATURE FLAGS
# ============================================
# Set to 'true' after Snapshot vote closes to open Ski Trip deposits
NEXT_PUBLIC_SKI_VOTE_RESOLVED=false

# ============================================
# ANTHROPIC — AGENT TEAM
# ============================================
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# CONTACT EMAILS (public)
# ============================================
NEXT_PUBLIC_CONTACT_EMAIL=roadhousesyndicate@gmail.com
NEXT_PUBLIC_FOUNDER_EMAIL=daltonellscheid@gmail.com
