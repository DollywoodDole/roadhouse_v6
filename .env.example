# ============================================
# RoadHouse v6 — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SOLANA / WEB3
# ============================================

# 'devnet' for testing | 'mainnet-beta' for production
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Optional custom RPC (Helius, QuickNode). Leave blank = public endpoint.
NEXT_PUBLIC_SOLANA_RPC=

# $ROAD SPL Token mint address — set after running: npm run mint-token
NEXT_PUBLIC_ROAD_MINT_ADDRESS=

# NFT Collection addresses — set after Candy Machine deployment
NEXT_PUBLIC_NFT_FOUNDING_COLLECTION=
NEXT_PUBLIC_NFT_REGULAR_COLLECTION=
NEXT_PUBLIC_NFT_RANCH_COLLECTION=
NEXT_PUBLIC_NFT_PARTNER_COLLECTION=

# Treasury (Gnosis Safe multisig)
NEXT_PUBLIC_TREASURY_WALLET=
NEXT_PUBLIC_MULTISIG_WALLET=

# ============================================
# STRIPE
# ============================================

STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Merch (one-time)
NEXT_PUBLIC_STRIPE_PRICE_TEE=price_...
NEXT_PUBLIC_STRIPE_PRICE_HAT=price_...
NEXT_PUBLIC_STRIPE_PRICE_HOODIE=price_...
NEXT_PUBLIC_STRIPE_PRICE_STICKERS=price_...
NEXT_PUBLIC_STRIPE_PRICE_GLASS=price_...
NEXT_PUBLIC_STRIPE_PRICE_PHONE=price_...

# Memberships (recurring)
NEXT_PUBLIC_STRIPE_SUB_REGULAR=price_...
NEXT_PUBLIC_STRIPE_SUB_RANCH=price_...
NEXT_PUBLIC_STRIPE_SUB_PARTNER=price_...

# Event Tickets
NEXT_PUBLIC_STRIPE_PRICE_SKMT=price_...
NEXT_PUBLIC_STRIPE_PRICE_SUMMIT=price_...

# Sponsorship Packages
NEXT_PUBLIC_STRIPE_PRICE_SPONSOR_TB=price_...
NEXT_PUBLIC_STRIPE_PRICE_SPONSOR_FR=price_...
NEXT_PUBLIC_STRIPE_PRICE_SPONSOR_PR=price_...

# ============================================
# DISCORD BOT
# ============================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE_REGULAR=
DISCORD_ROLE_RANCH_HAND=
DISCORD_ROLE_PARTNER=

# ============================================
# CONTACT EMAILS
# ============================================
NEXT_PUBLIC_CONTACT_EMAIL=roadhousesyndicate@gmail.com
NEXT_PUBLIC_FOUNDER_EMAIL=daltonellscheid@gmail.com
