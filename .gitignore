# ──────────────────────────────────────────
# RoadHouse v6 — .gitignore
# ──────────────────────────────────────────

# Next.js
.next/
out/

# Dependencies
node_modules/

# ── ENVIRONMENT VARIABLES ─────────────────
# NEVER commit any .env file with real values
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# .env.example is safe to commit — it contains no real values

# ── SOLANA KEYPAIRS ───────────────────────
# Private keys — if these are committed, your treasury is compromised
scripts/keypairs/
*.json.key
deployer.json
authority.json
treasury.json
*.keypair

# ── SECRETS & KEYS (catch-all) ────────────
*.pem
*.key
*.secret
*_secret*
*_private*

# ── OS ────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Editor ────────────────────────────────
.vscode/settings.json
.idea/

# ── Vercel ────────────────────────────────
.vercel

# ── Build artifacts ───────────────────────
.scripts-out/
tsconfig.tsbuildinfo

# ── Logs ─────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
