{
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "regions": [
    "iad1"
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/join",
      "destination": "/#membership",
      "permanent": false
    },
    {
      "source": "/discord",
      "destination": "https://discord.gg/wwhhKcnQJ3",
      "permanent": false
    },
    {
      "source": "/kick",
      "destination": "https://kick.com/dollywooddole",
      "permanent": false
    },
    {
      "source": "/x",
      "destination": "https://x.com/dollywooddole",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/motors/sync",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/motors/fb-token-check",
      "schedule": "0 12 * * *"
    }
  ]
}