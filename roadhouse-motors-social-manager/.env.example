# RoadHouse Motors Social Manager — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# From Vercel dashboard (same secret used by the cron sync)
CRON_SECRET=your_cron_secret_here

# From Anthropic console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Facebook (required for --live posting) ────────────────────────────────────

# Page ID (already set as default in script — override here if needed)
FB_PAGE_ID=1047748735096733

# Long-lived Page Access Token
# How to get it:
#
#   Step 1 — Create a Meta App (if you don't have one):
#     https://developers.facebook.com/apps/creation/
#     Choose "Business" type. Connect it to your page.
#
#   Step 2 — Get a short-lived User Token:
#     https://developers.facebook.com/tools/explorer/
#     Select your app → add permissions:
#       pages_manage_posts
#       pages_read_engagement
#     Click "Generate Access Token" and grant access to your page.
#
#   Step 3 — Exchange for a long-lived User Token (60-day):
#     GET https://graph.facebook.com/oauth/access_token
#       ?grant_type=fb_exchange_token
#       &client_id={YOUR_APP_ID}
#       &client_secret={YOUR_APP_SECRET}
#       &fb_exchange_token={SHORT_LIVED_USER_TOKEN}
#
#   Step 4 — Get your Page Access Token from the long-lived user token:
#     GET https://graph.facebook.com/me/accounts?access_token={LONG_LIVED_USER_TOKEN}
#     Find your page in the response and copy its "access_token" value.
#     Page tokens derived from long-lived user tokens never expire.
#
FB_PAGE_ACCESS_TOKEN=
