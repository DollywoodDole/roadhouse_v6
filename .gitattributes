# Normalize line endings to LF on commit, checkout with native endings
* text=auto eol=lf

# Force LF for all JS/TS/JSON source files (clasp + Next.js)
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf

# Binary — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
